# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_... (replaces the legacy anon key)
SUPABASE_SECRET_KEY=                # sb_secret_... (replaces the legacy service_role key) — server-only, NEVER expose with NEXT_PUBLIC_
SUPABASE_DB_URL=                    # direct Postgres connection for migrations / RLS tests

# --- Stripe ---
STRIPE_SECRET_KEY=                  # server-only
STRIPE_WEBHOOK_SECRET=              # signature verification for the webhook handler
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # publishable key is safe client-side
# Stripe price IDs are intentionally omitted: tier pricing lives in the `tiers`
# table and is never hardcoded or env-baked.

# --- Resend ---
RESEND_API_KEY=                     # server-only
# Stopgap: send from the verified Afterload domain until MPPGA's
# production domain is provisioned. Replies route to
# site_settings.contact_email (default mppga207@gmail.com) via the
# Reply-To header — change the From here, change the Reply-To in the
# admin Settings → Contact & site info tab.
RESEND_FROM_EMAIL=afterchaos@afterload.io
RESEND_FROM_NAME=Maine Professional Pet Groomers Association
